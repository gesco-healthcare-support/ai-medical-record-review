# Config for the full docker-compose stack (docker-compose.yml). Copy to a .env at the repo root:
#   cp deploy/env.docker.example .env
# Compose reads .env for ${VAR} substitution and injects these into the api + workers.
# NEVER commit the real .env (it is git-ignored). See docs/plans/2026-07-16-p8-local-stack.md.

# ---- required secrets ----
# The EXACT Flask-Security password salt from the legacy mrr_ai .env. Migrated logins ONLY verify
# with the real salt; NEW accounts work with any value. Set the real one before testing a
# migrated user's login.
SECURITY_PASSWORD_SALT=CHANGE_ME_real_flask_salt

# Cookie / token signing key, >= 32 bytes.  Generate:  openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_a_32_byte_key

# ---- database ----
POSTGRES_PASSWORD=mrr_local_only

# ---- environment ----
# dev  = session cookie NOT marked Secure -> works over http://localhost:8080 (local testing).
# prod = cookie Secure + Vertex hard-required -> use ONLY behind TLS (the in-house server).
ENVIRONMENT=dev

# ---- Vertex AI (the only external dependency; needed for identify / summarize / reprocess) ----
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
# Recommended for a long-running server: a service-account key JSON. Put the file at
# ./secrets/vertex-sa.json (git-ignored) and leave this pointing at the in-container path.
# Leave blank to skip Vertex (the app runs; only the AI jobs fail until a key is provided).
GOOGLE_APPLICATION_CREDENTIALS=/secrets/vertex-sa.json
