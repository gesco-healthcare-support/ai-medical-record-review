# Backend config (copy to backend/.env for local dev; never commit the real .env).
# Local self-hosted Postgres + Redis (docker-compose.dev.yml in dev; local services on the server).
DATABASE_URL=postgresql+psycopg://mrr:mrr_dev_only@localhost:5432/mrr
REDIS_URL=redis://localhost:6379/0

# Session cookie signing + the legacy password salt (carried over so existing hashes verify).
SECRET_KEY=change-me-32+random-bytes
SECURITY_PASSWORD_SALT=change-me-carry-over-from-flask-.env

# Gemini/Vertex. USE_VERTEXAI must be true in production (BAA path); the app fails fast otherwise.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Dev-only fallback when USE_VERTEXAI is not set (non-BAA; never for real PHI):
GEMINI_API_KEY=

# Uploaded PDFs (PHI at rest); keep off any network share.
UPLOAD_FOLDER=./uploads
