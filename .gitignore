# ---- Secrets / environment ----
.env
.env.*
!.env.example

# ---- PHI: NEVER commit patient data ----
# Uploaded medical records, generated outputs, and any extracted page maps.
uploads/
all_data_temp.txt
*.pdf
*.TRIAL.csv
*.TRIAL2.csv
# Experiment spikes derive OCR text/labels from real records - keep caches out.
experiments/**/cache/
experiments/**/outputs/
*.jsonl

# ---- Virtual environments (disposable; recreated via uv) ----
.venv/
.venv-trial/
myenv/
venv/
env/

# ---- Exploratory spikes (carry hardcoded key fallbacks and/or PHI sample paths) ----
gemini_trial*.py
diag_slice.py

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Coverage (generated by pytest --cov; consumed by SonarCloud in CI) ----
.coverage
coverage.xml
htmlcov/
.scannerwork/

