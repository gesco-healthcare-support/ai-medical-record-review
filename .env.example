# GEMINI_API_KEY=
# OPENAI_API_KEY=

# Route Gemini calls to Vertex AI (BAA-covered) instead of AI Studio.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=/secrets/adc.json

SECRET_KEY=
SECURITY_PASSWORD_SALT=

GENAI_MAX_RETRIES=10
GENAI_RETRY_MAX_DELAY=60
# Tesseract binary (installed but not on PATH -> empty OCR starves summarization).
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
