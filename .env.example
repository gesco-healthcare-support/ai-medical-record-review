# Copy this file to .env and fill in real values. NEVER commit .env.
#
# SECURITY: the keys originally hardcoded in the handoff are considered
# compromised (they lived in plaintext source). Rotate them and put the
# NEW values here. The app validates these at startup and fails fast if missing.

GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# --- Vertex AI routing (HIPAA/BAA) -------------------------------------------------
# Gemini via Vertex AI (aiplatform.googleapis.com) is covered by a Google Cloud BAA;
# the AI Studio Developer API (default) is NOT. Set this true for any PHI processing.
GOOGLE_GENAI_USE_VERTEXAI=true
#
# Vertex auth - choose ONE:
#   A) GCP API key: reuse GEMINI_API_KEY above (the key must be allowed to call the
#      "Vertex AI API" and that API must be enabled on its project). Leave the two
#      GOOGLE_CLOUD_* vars below UNSET for this path.
#   B) Service account / ADC (more robust): set the project + location and point
#      GOOGLE_APPLICATION_CREDENTIALS at the service-account JSON key file.
# GOOGLE_CLOUD_PROJECT=gen-lang-client-0785241985
# GOOGLE_CLOUD_LOCATION=global
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
#
# Optional: override the model id (Vertex default is gemini-2.5-flash) and cost rates.
# GENAI_MODEL=gemini-2.5-flash
